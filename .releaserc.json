{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    "@semantic-release/changelog",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i \"s/^version:.*/version: ${nextRelease.version}/\" chart/argocd-bitbucket-proxy/Chart.yaml && sed -i \"s/^appVersion:.*/appVersion: \\\"${nextRelease.version}\\\"/\" chart/argocd-bitbucket-proxy/Chart.yaml"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "chart/argocd-bitbucket-proxy/Chart.yaml",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
